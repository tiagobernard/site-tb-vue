\" class=\"btn btn-secondary btn-lg\">enviar</button>\n                </center>\n            </form>\n        </div>\n    </div>\n</template>\n\n<script>\nexport default {\n    name: 'Contatotb',\n    data() {\n        return {}\n    }\n}\n</script>\n\n<style scoped>\n.contato {background:#e8e8e8;}\ninput, textarea {font-family:\"Space Mono\", Helvetica, Arial, Verdana, sans-serif;}\nh3 {margin-bottom:15px;}\n</style>"],"sourceRoot":""}]}